    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
